# ============================================================
# Credit Scoring System - Environment Variables
# Másold ezt a fájlt .env névre és töltsd ki az értékeket.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=credit_user
POSTGRES_PASSWORD=credit_pass
POSTGRES_DB=credit_scoring_db
DATABASE_URL=postgresql+psycopg2://credit_user:credit_pass@postgres_db:5432/credit_scoring_db

# --- Flask ---
SECRET_KEY=change_me_in_production_a7f3b9c1d2e4
ADMIN_PASSWORD=Admin1234!

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5102
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://credit_user:credit_pass@postgres_db:5432/mlflow_db
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# --- Airflow ---
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres_airflow:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW_BASE_URL=http://airflow_webserver:8080
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow

# --- API ---
API_HOST=0.0.0.0
API_PORT=8080

# --- Docker Swarm ---
REPLICAS_API=2
REPLICAS_MLFLOW=1
